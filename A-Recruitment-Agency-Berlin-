function handleFile(input,tid){
  const fn=document.getElementById(tid);
  if(input.files.length>0){fn.textContent='📎 '+input.files[0].name;fn.style.display='block'}
}

async function submitForm(type,e){
  e.preventDefault();

  if(type==='co'){
    document.getElementById('co-form').style.display='none';
    document.getElementById('co-success').style.display='block';
    return;
  }

  if(!supabaseClient){
    alert('Supabase is not connected. Check SUPABASE_URL and SUPABASE_KEY.');
    return;
  }

  const cvInput=document.getElementById('cv-file');
  const cv=cvInput.files[0];
  if(!cv){ alert('CV is required.'); return; }

  const btn=document.getElementById('submit-btn');
  const oldText=btn.textContent;
  btn.disabled=true; btn.textContent='SENDING...';

  try{
    const safeName=(document.getElementById('name').value||'candidate').replace(/[^a-z0-9_-]+/gi,'_');
    const path=`public/${Date.now()}_${safeName}_${cv.name}`;
    const upload=await supabaseClient.storage.from('candidate-cvs').upload(path,cv,{upsert:false});
    if(upload.error) throw upload.error;

    const payload={
      full_name:document.getElementById('name').value,
      phone:document.getElementById('phone').value,
      email:document.getElementById('email').value || null,
      language:document.getElementById('language').value,
      status:'looking',
      notes:document.getElementById('description').value || null,
      cv_url:path
    };
    const ins=await supabaseClient.from('candidates').insert(payload);
    if(ins.error) throw ins.error;

    document.getElementById('cand-form').style.display='none';
    document.getElementById('cand-success').style.display='block';
  }catch(err){
    alert('Submission failed: '+err.message+'\n\nIf this is the public form, run the public INSERT policies I gave you in Supabase.');
  }finally{
    btn.disabled=false; btn.textContent=oldText;
  }
}


function toggleTheme(){
  document.body.classList.toggle('light');
  const isLight=document.body.classList.contains('light');
  localStorage.setItem('ta-theme',isLight?'light':'dark');
  const btn=document.getElementById('theme-toggle'); if(btn) btn.textContent=isLight?'☾ Dark':'☀ Light';
}
(function initTheme(){
  if(localStorage.getItem('ta-theme')==='light') document.body.classList.add('light');
  setTimeout(()=>{const btn=document.getElementById('theme-toggle'); if(btn) btn.textContent=document.body.classList.contains('light')?'☾ Dark':'☀ Light';},0);
})();

async function adminLogin(e){
  e.preventDefault();
  const email=document.getElementById('admin-email').value;
  const password=document.getElementById('admin-password').value;

  if(!supabaseClient){
    alert('Supabase is not connected. Check SUPABASE_URL and SUPABASE_KEY.');
    return;
  }

  const { error } = await supabaseClient.auth.signInWithPassword({ email, password });
  if(error){
    alert('Login failed: '+error.message);
    return;
  }

  document.getElementById('admin-login-form').style.display='none';
  document.getElementById('admin-login-msg').style.display='block';
  showPage('admin-dashboard');
  await loadCandidates();
}

async function adminLogout(){
  if(supabaseClient) await supabaseClient.auth.signOut();
  document.getElementById('admin-login-form').style.display='block';
  document.getElementById('admin-login-msg').style.display='none';
  showPage('admin-login');
}

let candidates=[];

async function uploadCv(file, prefix='admin'){
  if(!file) return null;
  const safe=file.name.replace(/[^a-z0-9_.-]+/gi,'_');
  const path=`${prefix}/${Date.now()}_${safe}`;
  const { error } = await supabaseClient.storage.from('candidate-cvs').upload(path,file,{upsert:false});
  if(error) throw error;
  return path;
}

async function saveCandidate(e){
  e.preventDefault();
  if(!supabaseClient){ alert('Supabase is not connected.'); return; }

  const editId=document.getElementById('edit-index').value;
  const cvFile=document.getElementById('ad-cv').files[0];
  const current=candidates.find(c=>c.id===editId);

  if(!editId && !cvFile){ alert('CV is required for new candidates.'); return; }

  const btn=e.target.querySelector('button[type="submit"]');
  const oldText=btn.textContent;
  btn.disabled=true; btn.textContent='SAVING...';

  try{
    let cvPath=current?.cv_url || null;
    if(cvFile) cvPath=await uploadCv(cvFile,'admin');

    const payload={
      full_name:document.getElementById('ad-name').value,
      phone:document.getElementById('ad-phone').value,
      language:document.getElementById('ad-language').value,
      email:document.getElementById('ad-email').value || null,
      status:document.getElementById('ad-status').value,
      notes:document.getElementById('ad-notes').value || null,
      cv_url:cvPath
    };

    let res;
    if(editId){
      res=await supabaseClient.from('candidates').update(payload).eq('id',editId);
    }else{
      res=await supabaseClient.from('candidates').insert(payload);
    }
    if(res.error) throw res.error;

    e.target.reset();
    document.getElementById('edit-index').value='';
    document.getElementById('ad-cv').required=true;
    await loadCandidates();
  }catch(err){
    alert('Save failed: '+err.message);
  }finally{
    btn.disabled=false; btn.textContent=oldText;
  }
}

function statusLabel(s){return s==='looking'?'Looking for job':s==='found'?'Found job':s==='pending'?'Missing info / follow-up':'Archived'}

async function getCvLink(path){
  if(!path || !supabaseClient) return '#';
  const { data, error }=await supabaseClient.storage.from('candidate-cvs').createSignedUrl(path,60*10);
  if(error) return '#';
  return data.signedUrl;
}

async function loadCandidates(){
  if(!supabaseClient) return;
  const { data, error } = await supabaseClient.from('candidates').select('*').order('created_at',{ascending:false});
  if(error){ alert('Could not load candidates: '+error.message); return; }
  candidates=data||[];
  renderCandidates();
}

async function renderCandidates(){
  const q=(document.getElementById('candidate-search')?.value||'').toLowerCase();
  const f=document.getElementById('candidate-filter')?.value||'all';
  const list=document.getElementById('candidate-list'); if(!list) return;
  list.innerHTML='';
  const filtered=candidates.filter(c=>{
    if(f!=='all' && c.status!==f) return false;
    const blob=[c.full_name,c.phone,c.language,c.email,c.notes].join(' ').toLowerCase();
    return !q || blob.includes(q);
  });
  if(filtered.length===0){ list.innerHTML='<p class="section-sub" style="text-align:left">No candidates found.</p>'; return; }
  for(const c of filtered){
    const cvLink=await getCvLink(c.cv_url);
    const div=document.createElement('div'); div.className='candidate-card';
    const cvName=c.cv_url ? c.cv_url.split('/').pop() : '-';
    div.innerHTML=`<h4><span class="status-dot st-${c.status||'looking'}"></span>${escapeHtml(c.full_name||'-')}</h4><div class="candidate-meta">Phone: ${escapeHtml(c.phone||'-')}<br>Language: ${escapeHtml(c.language||'-')}<br>Email: ${escapeHtml(c.email||'-')}<br>CV: ${c.cv_url?`<a class="cv-link" href="${cvLink}" target="_blank" rel="noopener">${escapeHtml(cvName)}</a>`:'-'}<br>Status: ${statusLabel(c.status||'looking')}<br>Created: ${(c.created_at||'').slice(0,10)||'-'}<br>Notes: ${escapeHtml(c.notes||'-')}</div><div class="card-actions"><button class="mini-btn gold" onclick="editCandidate('${c.id}')">Edit</button><button class="mini-btn" onclick="deleteCandidate('${c.id}')">Delete</button></div>`;
    list.appendChild(div);
  }
}

function escapeHtml(str){
  return String(str).replace(/[&<>'"]/g, s=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[s]));
}

function editCandidate(id){
  const c=candidates.find(x=>x.id===id); if(!c) return;
  showPage('admin-dashboard');
  document.getElementById('edit-index').value=c.id;
