  window.scrollTo(0,0);
}

function selectWho(g){
  ['worker','student','any'].forEach(id=>{
    document.getElementById('card-'+id).classList.toggle('selected',id===g);
    document.getElementById('chk-'+id).textContent=id===g?'✓':'';
  });
  document.getElementById('panel-student').classList.toggle('visible',g==='student');
}

function selectGoal(g){
  ['money','contract','freelance','open'].forEach(id=>{
    document.getElementById('card-'+id).classList.toggle('selected',id===g);
    document.getElementById('chk-'+id).textContent=id===g?'✓':'';
  });
  document.getElementById('panel-contract').classList.toggle('visible',g==='contract');
  document.getElementById('panel-freelance').classList.toggle('visible',g==='freelance');
