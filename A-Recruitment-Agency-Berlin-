<script>
const SUPABASE_URL = "https://gfbrxlrnytlebrsyylnc.supabase.co";
const SUPABASE_KEY = "sb_publishable_SLlFNsrTJyKVJpHnuPbq0w_MyXL9XlF";
const supabaseClient = (window.supabase && !SUPABASE_KEY.includes('PASTE_YOUR'))
  ? window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY)
  : null;

function showPage(p){
  document.querySelectorAll('.page').forEach(el=>el.classList.remove('active'));
